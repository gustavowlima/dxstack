{
  "name": "@stack/api",
  "private": true,
  "type": "module",
  "exports": {
    "./router": "./src/router/index.ts"
  },
  "scripts": {
    "with-env": "dotenv -e ../../.env -- bun",
    "dev": "bun run with-env --watch src/index.ts",
    "start": "bun run with-env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "check": "biome check ."
  },
  "dependencies": {
    "@orpc/server": "catalog:api",
    "@orpc/zod": "catalog:api",
    "@better-auth/drizzle-adapter": "1.6.9",
    "better-auth": "catalog:",
    "@stack/db": "workspace:*",
    "@stack/env": "workspace:*",
    "@stack/logger": "workspace:*",
    "@stack/shared": "workspace:*",
    "hono": "catalog:api",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "1.3.13",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "ultracite": "catalog:",
    "dotenv": "catalog:"
  }
}
