{
  "name": "@stack/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "check": "biome check ."
  },
  "dependencies": {
    "@orpc/server": "catalog:api",
    "@orpc/zod": "catalog:api",
    "@stack/auth": "workspace:*",
    "@stack/db": "workspace:*",
    "@stack/env": "workspace:*",
    "@stack/logger": "workspace:*",
    "@stack/shared": "workspace:*",
    "hono": "catalog:api",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "ultracite": "catalog:"
  }
}
