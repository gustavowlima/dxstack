{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "extends": ["../../biome.json", "ultracite/biome/react"],
  "files": {
    "includes": [
      "**/src/**/*",
      "**/.vscode/**/*",
      "**/index.html",
      "**/vite.config.ts",
      "!**/src/routeTree.gen.ts",
      "!**/src/styles.css"
    ]
  },
  "assist": {
